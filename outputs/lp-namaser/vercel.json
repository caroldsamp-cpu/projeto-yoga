{
  "rewrites": [
    { "source": "/respire", "destination": "/respire.html" }
  ],
  "redirects": [
    { "source": "/instagram", "destination": "/?utm_source=instagram&utm_medium=bio", "permanent": false },
    { "source": "/stories", "destination": "/?utm_source=instagram&utm_medium=stories", "permanent": false },
    { "source": "/whatsapp", "destination": "/?utm_source=whatsapp&utm_medium=direto", "permanent": false },
    { "source": "/youtube", "destination": "/?utm_source=youtube&utm_medium=descricao", "permanent": false },
    { "source": "/email", "destination": "/?utm_source=email&utm_medium=lista", "permanent": false },
    { "source": "/qr", "destination": "/?utm_source=qrcode&utm_medium=presencial", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Access-Control-Allow-Origin", "value": "https://namaser.vercel.app" }
      ]
    }
  ]
}
